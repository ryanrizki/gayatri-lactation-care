generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ServiceCategory {
  consultation
  class
}

model Service {
  id          String          @id
  name        String
  category    ServiceCategory
  price       Int
  description String
  features    String[]
  image       String
  modules     Module[]
  enrollments Enrollment[]
  sortOrder   Int             @default(0)
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Challenge {
  id                    String   @id
  title                 String
  icon                  String
  description           String
  criticalSymptoms      String[]
  immediateSteps        String[]
  interactiveDiagnostic Json
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Setting {
  key   String @id
  value Json
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String       @id @default(cuid())
  nama          String
  email         String       @unique
  passwordHash  String
  role          Role         @default(USER)
  enrollments   Enrollment[] @relation("UserEnrollments")
  confirmations Enrollment[] @relation("AdminConfirmations")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

enum MaterialType {
  PDF
  VIDEO
  LINK
}

model Module {
  id          String     @id @default(cuid())
  serviceId   String
  service     Service    @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  title       String
  description String     @default("")
  sortOrder   Int        @default(0)
  videoPath   String?
  durationSec Int?
  isPreview   Boolean    @default(false)
  materials   Material[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([serviceId])
}

model Material {
  id        String       @id @default(cuid())
  moduleId  String
  module    Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title     String
  type      MaterialType @default(PDF)
  filePath  String?
  isPreview Boolean      @default(false)
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([moduleId])
}

enum EnrollmentStatus {
  PENDING
  PAID
  CANCELLED
}

model Enrollment {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation("UserEnrollments", fields: [userId], references: [id], onDelete: Cascade)
  serviceId     String
  service       Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  status        EnrollmentStatus @default(PENDING)
  requestedAt   DateTime         @default(now())
  confirmedAt   DateTime?
  confirmedById String?
  confirmedBy   User?            @relation("AdminConfirmations", fields: [confirmedById], references: [id])
  note          String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([userId, serviceId])
  @@index([status])
}
